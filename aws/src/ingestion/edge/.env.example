# ──────────────────────────────────────────────
# 엣지 노드 환경변수 (.env 로 복사해서 사용)
# 담당: 정일혁 — 라즈베리파이 → AWS IoT Core 수집 경로 + 조명 명령 실행
# ──────────────────────────────────────────────

# ── AWS IoT Core 연결 ──
# 엔드포인트 확인: aws iot describe-endpoint --endpoint-type iot:Data-ATS
AWS_IOT_ENDPOINT=xxxxxxxxxxxxxx-ats.iot.ap-northeast-2.amazonaws.com
AWS_IOT_PORT=8883
AWS_REGION=ap-northeast-2

# 이 디바이스의 Thing 이름 (= deviceId = 토픽/정책 네임스페이스 기준)
# 규칙: rpi-edge-<room>-<seq>
IOT_THING_NAME=rpi-edge-bedroom-01
# 비우면 clientId = IOT_THING_NAME
IOT_CLIENT_ID=

# ── X.509 인증서 경로 (provision.sh 가 ./certs/ 에 생성) ──
IOT_PRIVATE_KEY_PATH=./certs/private.pem.key
IOT_CERT_PATH=./certs/device.pem.crt
IOT_ROOT_CA_PATH=./certs/AmazonRootCA1.pem

# ── 동작 모드 ──
# true 로 두면 실제 IoT Core 에 접속하지 않고 발행될 내용만 로깅 (인증서 없는 PC 개발용).
# 엔드포인트나 인증서가 없으면 자동으로 dry-run 으로 폴백한다.
MOCK_IOT=
# true 면 실제 I2C 센서 대신 가짜 조도값 생성 (라즈베리파이 아닌 PC 개발용)
MOCK_SENSOR=true

# ── 센서 / 발행 ──
SENSOR_PUBLISH_INTERVAL_MS=3000
PCF8591_I2C_BUS=1
PCF8591_I2C_ADDRESS=72
PCF8591_CHANNEL=0
PCF8591_INVERT=false

# ── 조명 actuation (Device Shadow desired → 엣지 GPIO 실행) ──
# BCM 핀 번호 (하드웨어 PWM). pigpio 미설치/비 RPi 면 mock 로깅.
LIGHT_PWM_GPIO=18
# 데모용 시간 압축 배율 (1=실시간 SLEEP 30분/WAKE 15분, 0.01=약 100배 빠름).
LIGHTING_TIME_SCALE=1

# ── 로깅 ──
LOG_LEVEL=info
