# ── Fitbit OAuth 2.0 ─────────────────────────────────────────────────────────
# dev.fitbit.com > 앱 등록 (Application Type: Personal) 후 발급
FITBIT_CLIENT_ID=your_client_id
FITBIT_CLIENT_SECRET=your_client_secret
# 인증 콜백 URL — Fitbit 앱 설정의 Callback URL과 정확히 일치해야 함
FITBIT_REDIRECT_URI=http://localhost:3000/callback

# ── MQTT ─────────────────────────────────────────────────────────────────────
# 엣지 노드와 동일한 Mosquitto 브로커
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_BACKEND_CLIENT_ID=backend-data-01
MQTT_USERNAME=iot_user
MQTT_PASSWORD=iot_pass_2026
MQTT_KEEPALIVE_SEC=30

# 토픽 (edge node INTEGRATION.md와 동일하게 유지)
TOPIC_SENSOR_ILLUMINANCE=home/sensor/illuminance
TOPIC_DEVICE_STATUS=home/edge/status

# ── SQLite ───────────────────────────────────────────────────────────────────
DB_PATH=/home/pi/smart-sleep-lighting-onprem/backend/data/sleep.db

# ── 개발 환경 mock 모드 ────────────────────────────────────────────────────────
# Fitbit API 없이 가짜 수면 데이터로 실행
MOCK_FITBIT=false
# mock source 조도 데이터도 DB에 저장할지 여부 (기본: 실제 센서만)
STORE_MOCK_SENSOR=false

# ── 스케줄 ────────────────────────────────────────────────────────────────────
# Fitbit 수면 데이터 폴링 cron (기본: 매일 07:00 — 전날 수면 데이터 취득)
FITBIT_POLL_CRON=0 7 * * *
