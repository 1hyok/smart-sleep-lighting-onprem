# ──────────────────────────────────────────────
# .env.example — 엣지 노드 환경변수 템플릿
#  - 사용법: cp .env.example .env  → 실제 비밀번호 등 값 채우기
#  - 본 파일은 git 추적, 실제 .env 는 .gitignore.
#  - 신규 노드(다른 침실의 RPi 등) 추가 시 reference 로 사용.
# ──────────────────────────────────────────────

# [MQTT 브로커]
MQTT_BROKER_URL=mqtt://localhost:1883
# 멀티 디바이스 식별용 clientId. 명명 규칙: rpi-edge-{room}-{seq}
MQTT_CLIENT_ID=rpi-edge-bedroom-01
# Mosquitto 인증 (allow_anonymous=false 전제)
MQTT_USERNAME=iot_user
MQTT_PASSWORD=__REPLACE_WITH_STRONG_PASSWORD__
# 재연결 지수 백오프 (영구 단절 시 자원 고갈 방지)
#  - INITIAL 부터 시작해 실패 누적마다 2배씩 증가, MAX 에서 상한.
#  - 한 번이라도 connect 성공하면 INITIAL 로 리셋.
MQTT_RECONNECT_INITIAL_MS=2000
MQTT_RECONNECT_MAX_MS=60000
# Keepalive 주기(초). 브로커는 1.5× keepalive 동안 패킷이 없으면 LWT 발동.
#  - 30 → LWT 인지 ~45초. mqtt.js 기본값 60(인지 ~90초) 대비 단축.
MQTT_KEEPALIVE_SEC=30

# [토픽]
TOPIC_SENSOR_ILLUMINANCE=home/sensor/illuminance
# 백엔드 → 엣지 조명 제어 명령 (Subscribe). 페이로드: {level:0..100, durationMs?:number}
TOPIC_LIGHT_COMMAND=home/edge/light/command

# [센서 발행 주기]
SENSOR_PUBLISH_INTERVAL_MS=3000

# [YL-40 (PCF8591) I2C]
#  - PCF8591_I2C_BUS: RPi 의 /dev/i2c-N (Pi 2 이상 표준은 1)
#  - PCF8591_I2C_ADDRESS: 칩 기본 주소 (A0/A1/A2 점퍼 미납땜 기준 0x48)
#  - PCF8591_CHANNEL: LDR(조도) 가 연결된 채널. YL-40 보드 기본은 AIN0
#  - PCF8591_INVERT: 보드 분압 회로상 어두울수록 ADC 값이 올라가면 true
PCF8591_I2C_BUS=1
PCF8591_I2C_ADDRESS=0x48
PCF8591_CHANNEL=0
PCF8591_INVERT=true

# [LED PWM (조명 액추에이터)]
#  - LIGHT_GPIO_PIN: pigpio 로 PWM 출력할 BCM 핀 번호.
#    하드웨어 PWM 가능: 12, 13, 18, 19 (그 외도 소프트웨어 PWM 가능)
#  - MOCK_LIGHT: PC 개발 환경 또는 pigpio 미설치 환경에서 true 로 두면
#    실제 GPIO 쓰기 대신 듀티값을 로그로만 출력 (서버는 살아있음)
LIGHT_GPIO_PIN=18
MOCK_LIGHT=false

# [이벤트 로그]
#  - service_start / service_stop / sensor_error / uncaught_exception 등 기록.
#  - 운영 사용자(pi)가 쓸 수 있는 경로여야 함.
EVENT_LOG_PATH=/home/pi/smart-sleep-lighting-onprem/service_log.jsonl
